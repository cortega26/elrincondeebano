{
  "name": "astro-poc-elrincondeebano",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Active Astro storefront for ElRinconDeEbano.com",
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); ['dist','.astro'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true,maxRetries:10,retryDelay:100}));\"",
    "data:sync": "node scripts/sync-data.mjs",
    "assets:validate": "node scripts/validate-asset-contract.mjs",
    "contract:http": "node scripts/validate-http-contract.mjs",
    "contract:artifacts": "node scripts/validate-artifact-contract.mjs",
    "dev": "astro dev",
    "lint": "node ../node_modules/eslint/bin/eslint.js .",
    "typecheck": "astro check",
    "build": "npm run clean && npm run data:sync && astro build && node scripts/postbuild-legacy-pages.mjs && node scripts/postbuild-sitemap.mjs && npm run assets:validate && npm run contract:http && npm run contract:artifacts",
    "preview": "astro preview"
  },
  "dependencies": {
    "anymatch": "file:vendor/anymatch/anymatch-3.1.3.tgz",
    "astro": "6.1.5"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "anymatch": "$anymatch"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.9.3"
  }
}
