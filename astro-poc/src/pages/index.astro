---
import BaseLayout from '../layouts/BaseLayout.astro';
import CatalogControls from '../components/CatalogControls.astro';
import HomeBundlesSection from '../components/HomeBundlesSection.astro';
import HomeProductSection from '../components/HomeProductSection.astro';
import ProductGrid from '../components/ProductGrid.astro';
import ServiceGuideDialog from '../components/ServiceGuideDialog.astro';
import {
  getHomeFeaturedDeals,
  getHomeFeaturedStaples,
  getHomePrimaryCategories,
  getHomeQuickPicks,
  getHomepageCatalogInitialProducts,
  getStorefrontBundles,
  getStorefrontExperience,
  getStorefrontStatusItems,
  getStorefrontTrustItems,
} from '../lib/catalog';
import { createSharePreviewMetadata, DEFAULT_OG_IMAGE } from '../lib/seo';

const fallbackQuickPicks = getHomeQuickPicks();
const featuredStaples = getHomeFeaturedStaples();
const quickOrderItems = featuredStaples.slice(0, 4).length > 0 ? featuredStaples.slice(0, 4) : fallbackQuickPicks;
const quickOrderSkus = new Set(quickOrderItems.map((item) => item.sku));
const homepageCatalogProducts = getHomepageCatalogInitialProducts(28)
  .filter((item) => !quickOrderSkus.has(item.sku))
  .slice(0, 24);
const featuredDeals = getHomeFeaturedDeals();
const bundles = getStorefrontBundles();
const primaryCategories = getHomePrimaryCategories();
const trustItems = getStorefrontTrustItems();
const statusItems = getStorefrontStatusItems();
const trustMap = new Map(trustItems.map((item) => [item.label, item.value]));
const statusMap = new Map(statusItems.map((item) => [item.label, item.value]));
const heroHighlights = [
  {
    label: 'Pedidos hoy',
    value: statusMap.get('Pedidos hoy') || 'Abierto para vecinos de Ébano',
  },
  {
    label: 'Respuesta',
    value: statusMap.get('Respuesta') || 'Aprox. 10 minutos',
  },
  {
    label: 'Entrega',
    value: trustMap.get('Entrega') || 'Coordinada dentro del edificio',
  },
];
const heroPaymentCopy =
  trustMap.get('Pago') || 'Efectivo, transferencia y tarjeta desde $30.000.';
const storefrontExperience = getStorefrontExperience();
const sharePreview = createSharePreviewMetadata({
  title: 'El Rincón de Ébano',
  description:
    'Despensa, bebidas y aseo para residentes de Ébano. Haz tu pedido por WhatsApp y recibe dentro del edificio.',
  canonicalPath: '/',
  ogImage: DEFAULT_OG_IMAGE,
  ogImageAlt: 'Logotipo de El Rincón de Ébano',
});
---

<BaseLayout
  title={sharePreview.title}
  description={sharePreview.description}
  canonicalPath="/"
  sharePreview={sharePreview}
  showTrustStrip={false}
>
  <div class="home-layout">
    <section class="home-entry home-layout__entry" aria-labelledby="main-heading">
      <div class="home-entry__main">
        <div class="home-entry__copy">
          <p class="home-entry__eyebrow mb-0">Minimarket privado del edificio</p>
          <h1 id="main-heading">Básicos del día con entrega dentro de Ébano</h1>
          <p class="home-entry__lead mb-0">
            Despensa, bebidas y aseo para vecinos del edificio. Agrega aquí y confirma por WhatsApp.
          </p>
          <p class="home-entry__meta mb-0">{heroPaymentCopy}</p>
        </div>
        <ul class="home-entry__service-list" aria-label="Estado del servicio">
          {
            heroHighlights.map((item) => (
              <li class="home-entry__service-item">
                <span class="home-entry__service-label">{item.label}</span>
                <strong class="home-entry__service-value">{item.value}</strong>
              </li>
            ))
          }
        </ul>
        <div class="home-entry__actions">
          <a
            href="/combos/"
            class="btn btn-primary home-entry__cta"
            data-home-hero-cta
          >
            Ver combos
          </a>
          <button
            type="button"
            class="service-guide-trigger home-entry__help-link"
            data-service-dialog-trigger
            aria-haspopup="dialog"
            aria-controls="service-guide-dialog"
          >
            Cómo pedir
          </button>
        </div>
      </div>

      <div class="home-profile-strip" data-home-profile-strip aria-live="polite">
        <div data-home-profile-copy>
          <strong>Tu último pedido puede quedar listo en un toque.</strong>
          <span>Si quieres, deja una nota para el pedido y úsala también en la próxima compra.</span>
        </div>
        <button
          type="button"
          class="btn btn-outline-dark home-profile-strip__repeat"
          data-repeat-last-order
          disabled
          aria-disabled="true"
        >
          Repetir último pedido
        </button>
      </div>
    </section>

    <HomeProductSection
      headingId="home-quick-order-heading"
      title="Esenciales de hoy"
      description="Una salida rápida con los básicos que más se repiten entre vecinos para resolver bebidas, despensa, lácteos y aseo."
      items={quickOrderItems}
      className="home-layout__quick-order"
      gridId="home-personalized-grid"
      showProfileStrip={false}
      compactMobile={true}
    />

    <section class="home-section home-layout__catalog" aria-labelledby="products-heading">
      <div class="home-section__header">
        <h2 id="products-heading">Más con stock hoy</h2>
        <p id="catalog-main">
          Una vitrina breve del surtido útil para el edificio. Si no está aquí, entra por categoría y sigue armando tu pedido.
        </p>
      </div>
      <div class="home-category-shortcuts" aria-label="Categorías principales">
        {
          primaryCategories.map((category) => (
            <a class="btn btn-outline-dark poc-category-chip home-category-shortcuts__chip" href={category.modernPath}>
              {category.label}
            </a>
          ))
        }
      </div>
      <CatalogControls stickyMobile={true} />
      <ProductGrid
        items={homepageCatalogProducts}
        id="product-container"
        announce={true}
        compactMobile={true}
      />
      <div id="catalog-empty-state" class="alert alert-info d-none mt-3" role="status">
        No se encontraron productos con los filtros seleccionados.
      </div>
      <div id="catalog-controls" class="home-catalog-footer text-center my-4">
        <a href="/despensa/" class="btn btn-outline-primary">Ver categorías completas</a>
      </div>
    </section>

    {featuredDeals.length > 0 ? (
      <HomeProductSection
        headingId="home-deals-heading"
        title="Ahorra hoy"
        description="Ofertas activas para resolver el pedido sin revisar promociones por separado."
        items={featuredDeals}
        className="home-layout__deals"
        compactMobile={true}
      />
    ) : null}

    <HomeBundlesSection
      headingId="home-bundles-heading"
      title="Combos en un toque"
      description="Suma un pedido completo al carrito sin armarlo producto por producto y ajusta después si quieres."
      bundles={bundles}
      className="home-layout__bundles"
      limit={3}
      introHref="/combos/"
      introLabel="Ver todos los combos listos"
      footerHref="/combos/"
      footerLabel="Explorar combos"
    />
  </div>

  <ServiceGuideDialog targetHref="#products-heading" targetLabel="Ir al catálogo" />
  <script
    is:inline
    id="storefront-experience-data"
    type="application/json"
    set:html={JSON.stringify(storefrontExperience)}
  ></script>
</BaseLayout>
