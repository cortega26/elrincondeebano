---
import BaseLayout from '../layouts/BaseLayout.astro';
import CatalogControls from '../components/CatalogControls.astro';
import HomeBundlesSection from '../components/HomeBundlesSection.astro';
import HomeProductSection from '../components/HomeProductSection.astro';
import ProductGrid from '../components/ProductGrid.astro';
import ServiceGuideDialog from '../components/ServiceGuideDialog.astro';
import {
  getHomeFeaturedDeals,
  getHomeQuickPicks,
  getHomepageCatalogProducts,
  getStorefrontBundles,
} from '../lib/catalog';
import { createSharePreviewMetadata, DEFAULT_OG_IMAGE } from '../lib/seo';

const homepageCatalogProducts = getHomepageCatalogProducts();
const fallbackQuickPicks = getHomeQuickPicks();
const featuredDeals = getHomeFeaturedDeals();
const bundles = getStorefrontBundles();
const sharePreview = createSharePreviewMetadata({
  title: 'El Rincón de Ébano',
  description:
    'Minimarket privado para residentes del edificio Ébano. Haz tu pedido por WhatsApp y recibe dentro del edificio.',
  canonicalPath: '/',
  ogImage: DEFAULT_OG_IMAGE,
  ogImageAlt: 'Logotipo de El Rincón de Ébano',
});
---

<BaseLayout
  title={sharePreview.title}
  description={sharePreview.description}
  canonicalPath="/"
  sharePreview={sharePreview}
  showTrustStrip={false}
>
  <div class="home-layout">
    <section class="home-entry home-layout__entry" aria-labelledby="main-heading">
      <div class="home-entry__main">
        <div class="home-entry__copy">
          <h1 id="main-heading">Haz tu pedido en minutos</h1>
          <p class="home-entry__lead mb-0">
            Agrega aquí y confirma por WhatsApp al final.
          </p>
        </div>
        <div class="home-entry__actions">
          <a
            href="#home-bundles-heading"
            class="btn btn-primary home-entry__cta"
            data-home-hero-cta
          >
            Ver combos
          </a>
          <button
            type="button"
            class="home-entry__help"
            data-service-dialog-trigger
            aria-haspopup="dialog"
            aria-controls="service-guide-dialog"
          >
            Cómo pedir
          </button>
        </div>
      </div>

      <div class="home-profile-strip" data-home-profile-strip aria-live="polite">
        <div data-home-profile-copy>
          <strong>Tu último pedido puede quedar listo en un toque.</strong>
          <span>Si quieres, deja una nota para el pedido y úsala también en la próxima compra.</span>
        </div>
        <button
          type="button"
          class="btn btn-outline-dark home-profile-strip__repeat"
          data-repeat-last-order
          disabled
          aria-disabled="true"
        >
          Repetir último pedido
        </button>
      </div>
    </section>

    <HomeProductSection
      headingId="home-quick-order-heading"
      title="Compra rápida"
      description="Tus frecuentes aparecerán aquí. Mientras tanto, dejamos una selección útil para resolver rápido."
      items={fallbackQuickPicks}
      className="home-layout__quick-order"
      gridId="home-personalized-grid"
      showProfileStrip={false}
      compactMobile={true}
    />

    <section class="home-section home-layout__catalog" aria-labelledby="products-heading">
      <div class="home-section__header">
        <h2 id="products-heading">Catálogo principal</h2>
        <p id="catalog-main">
          Todo el catálogo queda aquí, con filtros y búsqueda para completar el pedido sin salir de la página.
        </p>
      </div>
      <CatalogControls stickyMobile={true} />
      <ProductGrid
        items={homepageCatalogProducts}
        id="product-container"
        announce={true}
        compactMobile={true}
      />
      <div id="catalog-empty-state" class="alert alert-info d-none mt-3" role="status">
        No se encontraron productos con los filtros seleccionados.
      </div>
      <div id="catalog-controls" class="text-center my-4">
        <button type="button" id="catalog-load-more" class="btn btn-outline-primary d-none">Cargar más productos</button>
      </div>
      <div id="catalog-sentinel" aria-hidden="true"></div>
    </section>

    {featuredDeals.length > 0 ? (
      <HomeProductSection
        headingId="home-deals-heading"
        title="Ahorra hoy"
        description="Ofertas activas para resolver el pedido sin revisar promociones por separado."
        items={featuredDeals}
        className="home-layout__deals"
        compactMobile={true}
      />
    ) : null}

    <HomeBundlesSection
      headingId="home-bundles-heading"
      title="Combos listos"
      description="Una forma rápida de sumar productos que normalmente se piden juntos."
      bundles={bundles}
      className="home-layout__bundles"
    />
  </div>

  <ServiceGuideDialog targetHref="#products-heading" targetLabel="Ir al catálogo" />
</BaseLayout>
