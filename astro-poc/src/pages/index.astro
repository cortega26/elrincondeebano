---
import BaseLayout from '../layouts/BaseLayout.astro';
import CatalogControls from '../components/CatalogControls.astro';
import HomeBundlesSection from '../components/HomeBundlesSection.astro';
import HomeProductSection from '../components/HomeProductSection.astro';
import ProductGrid from '../components/ProductGrid.astro';
import {
  getHomeFeaturedDeals,
  getHomeFeaturedStaples,
  getHomePrimaryCategories,
  getHomeQuickPicks,
  getHomeSecondaryCategories,
  getHomepageCatalogProducts,
  getStorefrontBundles,
} from '../lib/catalog';
import { createSharePreviewMetadata, DEFAULT_OG_IMAGE } from '../lib/seo';

const homepageCatalogProducts = getHomepageCatalogProducts();
const primaryCategories = getHomePrimaryCategories();
const secondaryCategories = getHomeSecondaryCategories();
const fallbackQuickPicks = getHomeQuickPicks();
const featuredDeals = getHomeFeaturedDeals();
const featuredStaples = getHomeFeaturedStaples();
const bundles = getStorefrontBundles();
const sharePreview = createSharePreviewMetadata({
  title: 'El Rincón de Ébano',
  description:
    'Minimarket privado para residentes del edificio Ébano. Haz tu pedido por WhatsApp y recibe dentro del edificio.',
  canonicalPath: '/',
  ogImage: DEFAULT_OG_IMAGE,
  ogImageAlt: 'Logotipo de El Rincón de Ébano',
});
---

<BaseLayout
  title={sharePreview.title}
  description={sharePreview.description}
  canonicalPath="/"
  sharePreview={sharePreview}
>
  <div class="home-layout">
    <section class="home-overview home-layout__hero" aria-labelledby="main-heading">
      <div class="home-overview__copy">
        <h1 id="main-heading">Pide más rápido dentro de Ébano</h1>
        <p class="home-overview__lead mb-0">
          Revisa categorías, arma el pedido aquí y usa WhatsApp solo para confirmar el resumen.
        </p>
      </div>
      <div class="home-overview__actions">
        <a
          href="#home-fast-track-heading"
          class="btn btn-primary home-overview__cta"
          data-home-hero-cta
        >
          Ver categorías
        </a>
        <button
          type="button"
          class="home-overview__help"
          data-service-dialog-trigger
          aria-haspopup="dialog"
          aria-controls="service-guide-dialog"
        >
          Cómo funciona
        </button>
      </div>
    </section>

    <section
      class="home-section home-section--mobile-shortcuts home-layout__shortcuts"
      aria-labelledby="home-fast-track-heading"
    >
      <div class="home-section__header">
        <h2 id="home-fast-track-heading">Categorías clave</h2>
        <p>Empieza por las secciones que más resuelven un pedido del día a día.</p>
      </div>

      <div class="category-shortcuts" data-home-category-shortcuts>
        {
          primaryCategories.map((category, index) => (
            <a
              class="category-shortcut"
              href={category.modernPath}
              data-home-category-shortcut
              data-shortcut-index={String(index)}
            >
              <span class="category-shortcut-title">{category.label}</span>
              <span class="category-shortcut-meta">Entrar directo</span>
            </a>
          ))
        }
      </div>

      {secondaryCategories.length > 0 ? (
        <div class="home-secondary-links" aria-label="Secciones secundarias">
          <span class="home-secondary-links__label">Otras secciones:</span>
          <div class="home-secondary-links__items">
            {secondaryCategories.map((category) => <a href={category.modernPath}>{category.label}</a>)}
          </div>
        </div>
      ) : null}
    </section>

    <HomeProductSection
      headingId="home-quick-order-heading"
      title="Compra rápida"
      description="Tus frecuentes aparecerán aquí. Mientras tanto, dejamos una selección útil para resolver rápido."
      items={fallbackQuickPicks}
      className="home-layout__desktop-quick home-desktop-only"
      gridId="home-personalized-grid-desktop"
      showProfileStrip={true}
      compactMobile={true}
    />

    {featuredDeals.length > 0 ? (
      <HomeProductSection
        headingId="home-deals-heading"
        title="Ahorra hoy"
        description="Ofertas activas para resolver el pedido rápido sin revisar todo el catálogo."
        items={featuredDeals}
        className="home-layout__desktop-deals home-desktop-only"
        compactMobile={true}
      />
    ) : null}

    <HomeBundlesSection
      headingId="home-bundles-heading"
      title="Combos listos"
      description="Una forma rápida de subir el pedido sin tener que buscar producto por producto."
      bundles={bundles}
      className="home-layout__desktop-bundles home-desktop-only"
    />

    <HomeProductSection
      headingId="home-staples-heading"
      title="Favoritos para resolver hoy"
      description="Productos que hacen más simple un pedido corto: básicos, bebida, lácteos y limpieza."
      items={featuredStaples}
      className="home-layout__desktop-staples home-desktop-only"
      compactMobile={true}
    />

    <section class="home-section home-layout__catalog" aria-labelledby="products-heading">
      <div class="home-section__header">
        <h2 id="products-heading">Catálogo principal</h2>
        <p id="catalog-main">
          Aquí empieza el pedido completo. Dejamos fuera de esta vista las secciones secundarias para que comprar sea más rápido.
        </p>
      </div>
      <CatalogControls stickyMobile={true} />
      <ProductGrid
        items={homepageCatalogProducts}
        id="product-container"
        announce={true}
        compactMobile={true}
      />
      <div id="catalog-empty-state" class="alert alert-info d-none mt-3" role="status">
        No se encontraron productos con los filtros seleccionados.
      </div>
      <div id="catalog-controls" class="text-center my-4">
        <button type="button" id="catalog-load-more" class="btn btn-outline-primary d-none">Cargar más productos</button>
      </div>
      <div id="catalog-sentinel" aria-hidden="true"></div>
    </section>

    <details class="home-merchandising home-layout__mobile-merchandising home-mobile-only" data-home-merchandising>
      <summary class="home-merchandising__summary">Más formas de comprar</summary>
      <div class="home-merchandising__content">
        <HomeProductSection
          headingId="home-quick-order-mobile-heading"
          title="Compra rápida"
          description="Tus frecuentes aparecerán aquí. Mientras tanto, dejamos una selección útil para resolver rápido."
          items={fallbackQuickPicks}
          className="home-merchandising__section"
          gridId="home-personalized-grid-mobile"
          showProfileStrip={true}
          compactMobile={true}
        />

        {featuredDeals.length > 0 ? (
          <HomeProductSection
            headingId="home-deals-mobile-heading"
            title="Ahorra hoy"
            description="Ofertas activas para resolver el pedido rápido sin revisar todo el catálogo."
            items={featuredDeals}
            className="home-merchandising__section"
            compactMobile={true}
          />
        ) : null}

        <HomeBundlesSection
          headingId="home-bundles-mobile-heading"
          title="Combos listos"
          description="Una forma rápida de subir el pedido sin tener que buscar producto por producto."
          bundles={bundles}
          className="home-merchandising__section"
        />

        <HomeProductSection
          headingId="home-staples-mobile-heading"
          title="Favoritos para resolver hoy"
          description="Productos que hacen más simple un pedido corto: básicos, bebida, lácteos y limpieza."
          items={featuredStaples}
          className="home-merchandising__section"
          compactMobile={true}
        />
      </div>
    </details>
  </div>

  <dialog
    id="service-guide-dialog"
    class="service-dialog"
    aria-labelledby="service-guide-title"
    aria-describedby="service-guide-description"
    aria-hidden="true"
  >
    <div class="service-dialog__surface">
      <div class="service-dialog__header">
        <h2 id="service-guide-title" class="service-dialog__title">Cómo pedir</h2>
        <button type="button" class="service-dialog__close" data-service-dialog-close aria-label="Cerrar instrucciones">
          Cerrar
        </button>
      </div>
      <p id="service-guide-description" class="service-dialog__description">
        La web te ayuda a elegir rápido y el cierre del pedido se hace por WhatsApp.
      </p>
      <ol class="service-dialog__steps mb-0">
        <li>
          <strong>Explora el catálogo.</strong>
          Usa categorías, búsqueda y ofertas para encontrar lo que necesitas.
        </li>
        <li>
          <strong>Ajusta tu pedido.</strong>
          Agrega productos, cambia cantidades y revisa el total antes de enviar.
        </li>
        <li>
          <strong>Confirma por WhatsApp.</strong>
          El resumen sale listo para enviar, sin reescribir el pedido, y asi coordinamos pago y entrega dentro del edificio.
        </li>
      </ol>
      <p class="service-dialog__note mb-0">
        Servicio exclusivo para residentes de Ébano. La entrega se coordina dentro del edificio.
      </p>
      <div class="service-dialog__actions">
        <a href="#products-heading" class="btn btn-primary" data-service-dialog-close>Ir al catálogo</a>
        <button type="button" class="btn btn-outline-secondary" data-service-dialog-close>Entendido</button>
      </div>
    </div>
  </dialog>
</BaseLayout>
