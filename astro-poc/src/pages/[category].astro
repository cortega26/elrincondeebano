---
import CategoryCatalogPage from '../components/CategoryCatalogPage.astro';
import { getCategoryRouteParams, resolveCategoryParamToKey } from '../lib/catalog';

export function getStaticPaths() {
  return getCategoryRouteParams().map(({ param, categoryKey }) => ({
    params: { category: param },
    props: { categoryKey },
  }));
}

const { category } = Astro.params;
const routeProps = Astro.props as { categoryKey?: string };
const categoryKey = routeProps.categoryKey || resolveCategoryParamToKey(category || '') || '';
---

<CategoryCatalogPage categoryKey={categoryKey} />
