---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductDetail from '../../components/ProductDetail.astro';
import { getProductsWithSku, type ProductWithSku } from '../../lib/catalog';
import { createSharePreviewMetadata, getProductOgImageUrl } from '../../lib/seo';

export function getStaticPaths() {
  return getProductsWithSku().map((item) => ({
    params: { sku: item.sku },
    props: { item },
  }));
}

const { item } = Astro.props as { item: ProductWithSku };
const canonicalPath = `/p/${item.sku}/`;
const productDescription = item.product.description
  ? `${item.product.description} - El Rincón de Ébano`
  : `Detalle de producto para ${item.product.name}.`;
const sharePreview = createSharePreviewMetadata({
  title: `${item.product.name} | El Rincón de Ébano`,
  description: productDescription,
  canonicalPath,
  ogImage: getProductOgImageUrl(item.product.image_path, item.product.category),
  ogImageAlt: item.product.name,
});
---

<BaseLayout
  title={sharePreview.title}
  description={sharePreview.description}
  canonicalPath={canonicalPath}
  sharePreview={sharePreview}
  pageType="product"
  structuredProducts={[
    {
      sku: item.sku,
      name: item.product.name,
      description: item.product.description,
      image: item.product.image_path,
      price: item.product.price,
      stock: Boolean(item.product.stock),
      brand: typeof item.product.brand === 'string' ? item.product.brand : undefined,
      category: item.product.category,
    },
  ]}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: item.product.category, url: `/${item.product.category.toLowerCase()}/` },
    { name: item.product.name, url: canonicalPath },
  ]}
>
  <ProductDetail item={item} />
</BaseLayout>
