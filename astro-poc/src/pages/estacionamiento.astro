---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createSharePreviewMetadata } from '../lib/seo';

const sharePreview = createSharePreviewMetadata({
  title: 'Estacionamiento | El Rincón de Ébano',
  description:
    'Reserva tu estacionamiento en el edificio Ébano por noche. Tarifas desde $4.000.',
  canonicalPath: '/estacionamiento/',
  ogImage: '/assets/images/og/parking.og.jpg',
  ogImageAlt: 'Estacionamiento El Rincón de Ébano',
});
---

<BaseLayout
  title={sharePreview.title}
  description={sharePreview.description}
  canonicalPath="/estacionamiento/"
  sharePreview={sharePreview}
  showTrustStrip={false}
  hideCartShortcut={true}
>
  <section class="category-intro mb-4" aria-labelledby="parking-page-heading">
    <div class="category-intro-copy">
      <div class="category-intro-headline">
        <h1 id="parking-page-heading" class="mb-0">Estacionamiento</h1>
      </div>
      <p class="category-summary mb-0">
        Reserva tu estacionamiento por noche. Selecciona las fechas y confirma
        por WhatsApp.
      </p>
    </div>
  </section>

  <!-- Pricing Legend -->
  <div class="pricing-legend mb-4" aria-label="Tabla de tarifas">
    <div class="pricing-legend__item">
      <span class="pricing-legend__swatch pricing-legend__swatch--regular" aria-hidden="true"></span>
      <span><strong>Domingo a jueves</strong> · $4.000 / noche (excepto feriados)</span>
    </div>
    <div class="pricing-legend__item">
      <span class="pricing-legend__swatch pricing-legend__swatch--high" aria-hidden="true"></span>
      <span
        ><strong>Viernes, sábado, vísperas y feriados</strong> · $5.000 /
        noche</span
      >
    </div>
  </div>

  <!-- Reservation Card -->
  <div class="parking-card">
    <div class="parking-dates">
      <div class="parking-field">
        <label for="parking-checkin">Llegada (check-in)</label>
        <input type="date" id="parking-checkin" class="form-control" />
      </div>
      <div class="parking-field">
        <label for="parking-checkout">Salida (check-out)</label>
        <input type="date" id="parking-checkout" class="form-control" />
      </div>
    </div>

    <div class="parking-section-title">Datos del conductor</div>
    <p class="parking-section-desc">
      Obligatorios para que conserjería autorice el ingreso y salida del
      vehículo.
    </p>
    <div class="parking-fields-group">
      <div class="parking-field">
        <label for="parking-driver">Nombre completo</label>
        <input
          type="text"
          id="parking-driver"
          class="form-control"
          placeholder="Ej. Juan Pérez"
          autocomplete="name"
        />
      </div>
      <div class="parking-field">
        <label for="parking-plate">Patente del vehículo</label>
        <input
          type="text"
          id="parking-plate"
          class="form-control"
          placeholder="Ej. ABC-123"
          autocomplete="off"
        />
      </div>
      <div class="parking-field">
        <label for="parking-apartment">N.° de departamento</label>
        <input
          type="text"
          id="parking-apartment"
          class="form-control"
          placeholder="Ej. 201"
          autocomplete="off"
        />
      </div>
    </div>

    <div class="parking-section-title">Método de pago</div>
    <p class="parking-section-desc">Selecciona cómo pagarás al retirar el vehículo.</p>
    <div class="parking-payment">
      <p id="parking-payment-hint" class="parking-payment-hint is-hidden" role="status" aria-live="polite">
        Tarjeta de crédito disponible desde CLP 30.000 en adelante.
      </p>
      <div class="parking-payment-options">
        <div class="form-check">
          <input class="form-check-input" type="radio" name="parkingPayment" id="parking-payment-cash" value="Efectivo" />
          <label class="form-check-label" for="parking-payment-cash">Efectivo</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="parkingPayment" id="parking-payment-transfer" value="Transferencia" />
          <label class="form-check-label" for="parking-payment-transfer">Transferencia</label>
        </div>
        <div class="form-check is-hidden" id="parking-payment-credit-container">
          <input class="form-check-input" type="radio" name="parkingPayment" id="parking-payment-credit" value="Tarjeta de Crédito" />
          <label class="form-check-label" for="parking-payment-credit">Tarjeta de Crédito</label>
        </div>
      </div>
    </div>

    <div id="parking-breakdown" class="parking-breakdown is-hidden">
      <div id="parking-breakdown-list"></div>
      <div id="parking-total" class="parking-total is-hidden"></div>
    </div>

    <div id="parking-message" class="is-hidden" role="status" aria-live="polite"></div>

    <button
      id="parking-submit"
      class="btn btn-primary parking-submit"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
        style="margin-right: 0.45rem;"
      >
        <line x1="22" y1="2" x2="11" y2="13" />
        <polygon points="22 2 15 22 11 13 2 9 22 2" />
      </svg>
      Enviar reserva por WhatsApp
    </button>
  </div>

  <script>
    import '../scripts/parking-reservation.js';
  </script>
</BaseLayout>
