---
import 'bootstrap/dist/css/bootstrap.min.css';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import TrustStrip from '../components/TrustStrip.astro';
import { getNavigationGroups, getStorefrontExperience } from '../lib/catalog';
import {
  absoluteUrl,
  createSharePreviewMetadata,
  DEFAULT_OG_IMAGE,
  OG_IMAGE_HEIGHT,
  OG_IMAGE_TYPE,
  OG_IMAGE_WIDTH,
  SITE_NAME,
  type SharePreviewMetadata,
} from '../lib/seo';

export interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  canonicalUrl?: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  sharePreview?: SharePreviewMetadata;
}

const {
  title,
  description = 'Minimarket privado para residentes del edificio Ébano. Pedidos por WhatsApp y entrega dentro del edificio.',
  canonicalPath = Astro.url.pathname || '/',
  canonicalUrl,
  robots,
  ogTitle = title,
  ogDescription = description,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageAlt = 'Logotipo de El Rincón de Ébano',
  ogType = 'website',
  sharePreview,
} = Astro.props;

const navGroups = getNavigationGroups();
const storefrontExperience = getStorefrontExperience();
const resolvedSharePreview =
  sharePreview ||
  createSharePreviewMetadata({
    title: ogTitle || title,
    description: ogDescription || description,
    canonicalPath,
    canonicalUrl,
    ogImage,
    ogImageAlt,
    ogType,
  });
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={resolvedSharePreview.description} />
    <link rel="canonical" href={resolvedSharePreview.canonicalUrl} />
    {robots ? <meta name="robots" content={robots} /> : null}
    <link rel="manifest" href="/app.webmanifest" />

    <meta property="og:title" content={resolvedSharePreview.title} />
    <meta property="og:description" content={resolvedSharePreview.description} />
    <meta property="og:image" content={resolvedSharePreview.ogImage} />
    <meta property="og:image:type" content={OG_IMAGE_TYPE} />
    <meta property="og:image:alt" content={resolvedSharePreview.ogImageAlt} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:url" content={resolvedSharePreview.ogUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={resolvedSharePreview.ogType} />
    <meta name="twitter:card" content={resolvedSharePreview.twitterCard} />
    <meta name="twitter:title" content={resolvedSharePreview.title} />
    <meta name="twitter:description" content={resolvedSharePreview.description} />
    <meta name="twitter:image" content={resolvedSharePreview.ogImage} />
    <title>{resolvedSharePreview.title}</title>

    <link rel="icon" href={absoluteUrl('/assets/images/web/favicon.ico')} type="image/x-icon" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <Navbar navGroups={navGroups} />

    <main id="main-content" role="main" tabindex="-1">
      <div class="container storefront-shell mb-4">
        <TrustStrip />
        <slot />
      </div>
    </main>
    <button id="mobile-cart-shortcut" class="mobile-cart-shortcut is-hidden" type="button" aria-label="Ver pedido">
      Ver pedido
    </button>
    <div id="offline-indicator" aria-live="assertive" class="alert alert-warning is-hidden" role="alert">
      Actualmente estás sin conexión
    </div>

    <footer id="footer-container" role="contentinfo" class="bg-dark text-light py-3">
      <div class="container footer-content">
        <p class="mb-0">
          © El Rincón de Ébano — Minimarket privado para residentes del edificio. Pedidos coordinados por WhatsApp.<br/>
          <small class="text-muted">Hecho con ❤️ por <a href="https://tooltician.com/" target="_blank" rel="noopener" class="text-light text-decoration-none">Tooltician</a></small>
        </p>
      </div>
    </footer>

    <script
      is:inline
      id="storefront-experience-data"
      type="application/json"
      set:html={JSON.stringify(storefrontExperience)}
    ></script>
    <script>
      import '../scripts/storefront.js';
    </script>
  </body>
</html>
