---
import type { ProductWithSku } from '../lib/catalog';
import { formatPrice, getProductCardImageSource } from '../lib/catalog';

export interface Props {
  item: ProductWithSku;
  index?: number;
  compactMobile?: boolean;
}

const { item } = Astro.props;
const { product, sku } = item;
const { index = 0 } = Astro.props;
const { compactMobile = false } = Astro.props;
const isLikelyLcp = index === 0;
const price = typeof product.price === 'number' ? product.price : 0;
const discount = typeof product.discount === 'number' ? product.discount : 0;
const finalPrice = Math.max(price - discount, 0);
const hasDiscount = discount > 0 && price > 0 && finalPrice < price;
const discountPercent = hasDiscount ? Math.round((discount / price) * 100) : 0;
const image = getProductCardImageSource(product.image_path);
const avifImage = getProductCardImageSource(product.image_avif_path);
const hasAvifSource = typeof avifImage.srcset === 'string' && avifImage.srcset.length > 0;
---

<article
  class={`producto col-6 col-sm-6 col-md-4 col-lg-3 mb-4 ${product.stock ? '' : 'agotado'} ${compactMobile ? 'producto--compact-mobile' : ''}`.trim()}
  data-product-id={sku}
  data-product-name={product.name}
  data-product-category={product.category}
  data-product-price={price}
  data-product-discount={discount}
  data-product-final-price={finalPrice}
  data-product-order={index}
  data-compact-mobile={compactMobile ? 'true' : 'false'}
>
  <div class="card h-100">
    <div class="product-card__media">
      {hasDiscount ? (
        <span class="discount-badge badge bg-danger" aria-label="Producto en oferta">
          -{discountPercent}%
        </span>
      ) : null}

      <picture>
        {
          hasAvifSource ? (
            <source srcset={avifImage.srcset} sizes={avifImage.sizes} type="image/avif" />
          ) : null
        }
        <img
          src={image.src}
          srcset={image.srcset}
          sizes={image.sizes}
          alt={product.name}
          class="card-img-top product-thumb"
          loading={isLikelyLcp ? 'eager' : 'lazy'}
          fetchpriority={isLikelyLcp ? 'high' : 'auto'}
          decoding="async"
          width="200"
          height="200"
        />
      </picture>
    </div>

    <div class="card-body d-flex flex-column">
      <div class="product-card__copy">
        <h3 class="card-title mb-0">{product.name}</h3>
        {product.description ? <p class="card-text mb-0">{product.description}</p> : null}
      </div>

      <div class="precio-container product-card__pricing mb-2">
        {
          hasDiscount ? (
            <>
              <span class="precio-descuento" aria-label="Precio con descuento">
                {formatPrice(finalPrice)}
              </span>
              <span class="precio-original" aria-label="Precio original">
                <span class="tachado">{formatPrice(price)}</span>
              </span>
            </>
          ) : (
            <span class="precio" aria-label="Precio">{formatPrice(price)}</span>
          )
        }
      </div>

      <div class="action-area mt-auto" data-pid={sku} role="group" aria-label={`Acciones para ${product.name}`}>
        <button class="btn btn-primary add-to-cart-btn mt-2" type="button" data-id={sku} aria-label={`Agregar ${product.name} al carrito`}>
          <span class="add-to-cart-btn__label">Agregar</span>
          {compactMobile ? null : <span class="add-to-cart-btn__hint">al pedido</span>}
        </button>

        <div class="quantity-control is-hidden" aria-live="polite" role="group" aria-label="Seleccionar cantidad">
          <button class="quantity-btn" type="button" data-action="decrease" data-id={sku} aria-label="Disminuir cantidad">-</button>
          <span class="quantity-value" data-id={sku} aria-live="polite" aria-atomic="true">1</span>
          <button class="quantity-btn" type="button" data-action="increase" data-id={sku} aria-label="Aumentar cantidad">+</button>
        </div>
      </div>
    </div>
  </div>
</article>
