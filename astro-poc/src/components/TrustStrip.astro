---
import { getStorefrontStatusItems, getStorefrontTrustItems } from '../lib/catalog';

const trustItems = getStorefrontTrustItems();
const statusItems = getStorefrontStatusItems();

const trustMap = new Map(trustItems.map((item) => [item.label, item.value]));
const statusMap = new Map(statusItems.map((item) => [item.label, item.value]));

const summaryCards = [
  {
    title: 'Solo residentes',
    detail: trustMap.get('Acceso') || 'Servicio exclusivo del edificio.',
  },
  {
    title: 'Entrega dentro de Ébano',
    detail: trustMap.get('Entrega') || 'Coordinada dentro del edificio.',
  },
  {
    title: 'Respuesta aprox. 10 min',
    detail: statusMap.get('Respuesta') || 'Confirmamos rápido cuando estamos operando.',
  },
  {
    title: 'Confirmación por WhatsApp',
    detail: trustMap.get('Cierre') || 'El resumen final se envía por WhatsApp.',
  },
];
---

<section class="trust-strip" aria-label="Resumen del servicio">
  <div class="trust-strip__grid">
    {summaryCards.map((item) => (
      <div class="trust-strip__card">
        <strong>{item.title}</strong>
        <span>{item.detail}</span>
      </div>
    ))}
  </div>
</section>
