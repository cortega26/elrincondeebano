---
import ProductCard from './ProductCard.astro';
import type { ProductWithSku } from '../lib/catalog';

export interface Props {
  items: ProductWithSku[];
  id?: string;
  className?: string;
  announce?: boolean;
  compactMobile?: boolean;
}

const { items, id, className = '', announce = false, compactMobile = false } = Astro.props;
---

<div
  class={`row ${className}`.trim()}
  id={id}
  aria-live={announce ? 'polite' : undefined}
  data-total-products={items.length}
>
  {items.map((item, index) => <ProductCard item={item} index={index} compactMobile={compactMobile} />)}
</div>
