---
import type { NavGroup } from '../lib/catalog';
import { publicAssetUrl } from '../lib/seo';

export interface Props {
  navGroups: NavGroup[];
}

const { navGroups } = Astro.props;
---

<header id="navbar-container" role="banner">
  <nav class="navbar navbar-expand-xl navbar-dark bg-dark fixed-top" aria-label="Navegación principal">
    <div class="container-fluid">
      <a class="navbar-brand d-flex align-items-center" href="/">
        <picture>
          <source
            type="image/avif"
            srcset={`${publicAssetUrl('/assets/images/web/logo-40.avif')} 40w, ${publicAssetUrl('/assets/images/web/logo-80.avif')} 80w, ${publicAssetUrl('/assets/images/web/logo-120.avif')} 120w`}
            sizes="40px"
          />
          <img
            src={publicAssetUrl('/assets/images/web/logo-40.webp')}
            srcset={`${publicAssetUrl('/assets/images/web/logo-40.webp')} 40w, ${publicAssetUrl('/assets/images/web/logo-80.webp')} 80w, ${publicAssetUrl('/assets/images/web/logo-120.webp')} 120w`}
            sizes="40px"
            alt="Logo de El Rincón de Ébano"
            width="40"
            height="40"
            class="d-inline-block align-top me-1"
            loading="eager"
            decoding="async"
          />
        </picture>
        <span class="brand-text">El Rincón de Ébano</span>
      </a>

      <div class="d-flex align-items-center order-lg-last">
        <button
          class="navbar-toggler me-2"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Alternar navegación"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <button class="nav-link text-light" id="cart-icon" aria-label="Carrito de compras" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M7 4h-2l-1 2h2l3.6 7.59-1.35 2.45A1 1 0 0 0 9 18h9v-2H9.42a.25.25 0 0 1-.22-.37L10.1 14h5.45a1 1 0 0 0 .9-.55l3.24-6.45A1 1 0 0 0 19.8 5H7.42l-.42-1zM7 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path>
          </svg>
          <span
            class="badge bg-danger"
            id="cart-count"
            data-initialized="0"
            aria-live="polite"
            aria-atomic="true"
            aria-label="0 productos en el carrito"
          ></span>
        </button>
      </div>

      <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
        <ul class="navbar-nav">
          {
            navGroups.map((group) => (
              <li class="nav-item dropdown" data-bs-auto-close="outside">
                <button
                  class="nav-link dropdown-toggle"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                >
                  {group.label}
                </button>
                <ul class="dropdown-menu">
                  {group.categories.map((category) => (
                    <li><a class="dropdown-item" href={category.modernPath}>{category.label}</a></li>
                  ))}
                </ul>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </nav>
</header>

<div class="offcanvas offcanvas-end" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel" role="dialog" aria-modal="true">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="cartOffcanvasLabel" tabindex="-1">Tu pedido</h5>
    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
  </div>
  <div class="offcanvas-body">
    <div id="cart-items">
      <div class="alert alert-info mb-0 cart-empty-message" role="status" tabindex="-1">
        Tu carrito está vacío. Agrega productos antes de realizar el pedido.
      </div>
    </div>
    <div class="cart-footer">
      <div id="cart-total">Total: $0</div>
      <p class="checkout-note mb-0">
        Arma el pedido aquí y usa WhatsApp solo para confirmar el resumen. Asi reduces ida y vuelta y aceleras la entrega.
      </p>
      <div class="cart-note-toggle-row">
        <button
          class="cart-note-toggle"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#cart-note-collapse"
          aria-expanded="false"
          aria-controls="cart-note-collapse"
        >
          Añadir nota al pedido
        </button>
      </div>
      <div class="collapse" id="cart-note-collapse">
        <div class="cart-customer-panel">
          <div class="cart-customer-fields">
            <div>
              <label class="form-label" for="delivery-note">Nota opcional</label>
              <textarea
                class="form-control"
                id="delivery-note"
                rows="3"
                placeholder="Ej. si no hay Coca-Cola Zero, cambiar por normal; dejar en conserjería; sumar bolsa, etc."
              ></textarea>
              <p class="cart-note-hint">Se guarda en este dispositivo y se incluye en el resumen de WhatsApp.</p>
            </div>
          </div>
        </div>
      </div>
      <div id="payment-method-container">
        <label class="form-label d-block" for="payment-cash">Método de Pago</label>
        <p id="payment-threshold-hint" class="cart-payment-hint mb-2" role="status" aria-live="polite">
          Tarjeta disponible desde CLP 30.000 en el total del pedido.
        </p>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="paymentMethod" id="payment-cash" value="Efectivo" required />
          <label class="form-check-label" for="payment-cash">Efectivo</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="paymentMethod" id="payment-transfer" value="Transferencia" required />
          <label class="form-check-label" for="payment-transfer">Transferencia</label>
        </div>
        <div class="form-check d-none" id="payment-credit-container">
          <input class="form-check-input" type="radio" name="paymentMethod" id="payment-credit" value="Tarjeta de Crédito" required />
          <label class="form-check-label" for="payment-credit">Tarjeta de Crédito</label>
        </div>
        <div id="payment-error" class="text-danger small mt-2" role="alert" aria-live="assertive"></div>
      </div>
      <div id="substitution-preference-container">
        <label class="form-label d-block" for="substitution-preference">Si no hay stock</label>
        <select class="form-select" id="substitution-preference">
          <option value="Preguntar antes" selected>Preguntar antes</option>
          <option value="Reemplazar por algo similar">Reemplazar por algo similar</option>
          <option value="Quitar del pedido">Quitar del pedido</option>
        </select>
      </div>
      <div class="cart-footer-actions">
        <button id="submit-cart" class="btn btn-success cart-submit-btn" disabled aria-disabled="true">Enviar resumen por WhatsApp</button>
        <button id="continue-shopping" class="btn btn-outline-primary" data-bs-dismiss="offcanvas">Seguir comprando</button>
        <button id="empty-cart" class="btn btn-outline-secondary">Vaciar carrito</button>
      </div>
      <p id="submit-feedback" class="cart-submit-feedback mb-0" role="status" aria-live="polite"></p>
    </div>
  </div>
</div>
