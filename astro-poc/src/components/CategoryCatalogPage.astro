---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from './ProductGrid.astro';
import CatalogControls from './CatalogControls.astro';
import ServiceGuideDialog from './ServiceGuideDialog.astro';
import {
  getCategoryDescription,
  getCategoryLabel,
  getCategorySlug,
  getModernCategoryPath,
  getProductsByCategory,
} from '../lib/catalog';
import { createSharePreviewMetadata, getCategoryOgImageUrl } from '../lib/seo';

export interface Props {
  categoryKey: string;
  robots?: string;
}

const { categoryKey, robots } = Astro.props;
const products = getProductsByCategory(categoryKey);
const categoryLabel = getCategoryLabel(categoryKey);
const categoryDescription = getCategoryDescription(categoryKey);
const categorySlug = getCategorySlug(categoryKey).toLowerCase();
const canonicalPath = getModernCategoryPath(categoryKey);
const sharePreview = createSharePreviewMetadata({
  title: `El Rincón de Ébano - ${categoryLabel}`,
  description: categoryDescription,
  canonicalPath,
  ogImage: getCategoryOgImageUrl(categorySlug),
  ogImageAlt: `Imagen de ${categoryLabel}`,
});
---

<BaseLayout
  title={sharePreview.title}
  description={sharePreview.description}
  canonicalPath={canonicalPath}
  robots={robots}
  sharePreview={sharePreview}
  showTrustStrip={false}
>
  <section class="category-intro mb-4" aria-labelledby="category-heading">
    <div class="category-intro-copy">
      <div class="category-intro-headline">
        <h1 id="category-heading" class="mb-0">{categoryLabel}</h1>
        <button
          type="button"
          class="service-guide-trigger"
          data-service-dialog-trigger
          aria-haspopup="dialog"
          aria-controls="service-guide-dialog"
        >
          Cómo pedir
        </button>
      </div>
      <p class="category-summary mb-0">
        Solo residentes de Ébano. Cierre del pedido por WhatsApp.
      </p>
    </div>
  </section>

  {
    products.length > 0 ? (
      <>
        <CatalogControls stickyMobile={true} />
        <ProductGrid items={products} id="product-container" announce={true} compactMobile={true} />
        <div id="catalog-empty-state" class="alert alert-info d-none mt-3" role="status">
          No se encontraron productos con los filtros seleccionados.
        </div>
        <div id="catalog-controls" class="text-center my-4">
          <button type="button" id="catalog-load-more" class="btn btn-outline-primary d-none">Cargar más productos</button>
        </div>
        <div id="catalog-sentinel" aria-hidden="true"></div>
      </>
    ) : (
      <div class="alert alert-info" role="status">
        No hay productos disponibles en esta categoría.
      </div>
    )
  }
  <ServiceGuideDialog targetHref="#product-container" targetLabel="Ir a productos" />
</BaseLayout>
