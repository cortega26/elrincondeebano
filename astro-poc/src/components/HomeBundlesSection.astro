---
import type { StorefrontBundle } from '../lib/catalog';
import { formatPrice } from '../lib/catalog';

export interface Props {
  headingId: string;
  title: string;
  description: string;
  bundles: StorefrontBundle[];
  className?: string;
}

const { headingId, title, description, bundles, className = '' } = Astro.props;
---

<section class={`home-section ${className}`.trim()} aria-labelledby={headingId}>
  <div class="home-section__header">
    <h2 id={headingId}>{title}</h2>
    <p>{description}</p>
  </div>

  <div class="bundle-grid">
    {
      bundles.map((bundle) => (
        <article class="bundle-card">
          {bundle.savingsPercent > 0 && (
            <div class="bundle-card__savings-badge" aria-label={`Ahorra ${bundle.savingsPercent}%`}>
              -{bundle.savingsPercent}%
            </div>
          )}
          <div class="bundle-card__content">
            <h3>{bundle.title}</h3>
            <p>{bundle.description}</p>
            <ul class="bundle-card__items">
              {bundle.itemsResolved.map((item) => <li>{item.product.name}</li>)}
            </ul>
          </div>
          <div class="bundle-card__footer">
            <div class="bundle-card__meta">
              {bundle.bundlePrice && bundle.bundlePrice > 0 ? (
                <>
                  <strong>{formatPrice(bundle.bundlePrice)}</strong>
                  <span class="bundle-card__original-price">{formatPrice(bundle.totalPrice)}</span>
                </>
              ) : (
                <strong>{formatPrice(bundle.totalPrice)}</strong>
              )}
              <span>{bundle.itemsResolved.length} productos</span>
            </div>
            <button
              type="button"
              class="btn btn-outline-dark bundle-card__action"
              data-bundle-id={bundle.id}
              data-bundle-items={bundle.itemsResolved.map((item) => item.sku).join(',')}
            >
              Agregar combo
            </button>
          </div>
        </article>
      ))
    }
  </div>
</section>
