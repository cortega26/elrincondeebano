{
  "name": "elrincondeebano",
  "version": "1.0.0",
  "description": "Providing a bilingual-friendly grocery catalog that ships as a static site, pre-caches critical assets, and keeps operations reproducible through scripted builds.",
  "main": "service-worker.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "fonts": "node tools/fetch-fonts.mjs",
    "categories:sync": "node tools/sync-category-catalog.js",
    "preflight": "npm run categories:sync && npm run images:avif && npm run images:og:home && npm run images:og:overrides && npm run images:og:categories && node tools/preflight.js",
    "build": "npm run preflight && npm --prefix astro-poc run build",
    "lint": "eslint .",
    "check:determinism": "node tools/check-determinism-paths.mjs",
    "check:css-order": "node scripts/check-css-order.mjs",
    "format": "prettier --write .",
    "icons": "node tools/generate-icons.js",
    "validate:categories": "npm run categories:sync && node tools/validate-category-registry.js",
    "images:variants": "node tools/generate-image-variants.js",
    "images:avif": "node tools/sync-avif-assets.js",
    "images:og:home": "node tools/generate-home-og.mjs",
    "images:generate": "node tools/generate-images.mjs",
    "images:og:overrides": "node tools/sync-category-og-overrides.mjs",
    "images:og:categories": "node tools/generate-category-og.mjs",
    "canary:post-deploy": "node tools/post-deploy-canary.mjs --base-url https://www.elrincondeebano.com",
    "taxonomy:release": "node tools/taxonomy-release.mjs release",
    "taxonomy:rollback": "node tools/taxonomy-release.mjs rollback",
    "images:rewrite": "node tools/rewrite-images.mjs",
    "lint:images": "node tools/lint-images.mjs",
    "guardrails": "node tools/guardrails/run.mjs",
    "guardrails:assets": "node tools/guardrails/orphan-assets.js --report reports/orphan-assets/latest.json",
    "security:secret-scan": "node tools/guardrails/secret-scan.mjs",
    "ci:guardrails": "npm run build && npm run lint:images && npm run guardrails && npm run guardrails:assets",
    "prune:backups": "node tools/prune-backups.js",
    "test": "node test/run-all.js && vitest run",
    "test:coverage": "npx c8 npm test",
    "typecheck:legacy": "tsc -p tsconfig.typecheck.json",
    "typecheck:astro": "npm --prefix astro-poc run typecheck",
    "typecheck": "npm run typecheck:legacy && npm run typecheck:astro",
    "test:cypress": "node scripts/run-cypress.mjs --spec cypress/e2e/nav_menu.cy.ts",
    "test:e2e": "playwright test -c playwright.astro.config.ts --trace on",
    "test:e2e:astro": "npm run test:e2e",
    "test:e2e:visual": "playwright test test/e2e/visual-regression.spec.ts --project=chromium-desktop --trace on",
    "test:e2e:visual:update": "playwright test test/e2e/visual-regression.spec.ts --project=chromium-desktop --update-snapshots --trace on",
    "smoke:manual": "node scripts/smoke-checklist.mjs",
    "smoke:evidence": "node scripts/smoke-evidence.mjs",
    "monitor:live-contract": "node tools/live-contract-monitor.mjs --timeout-ms 15000 --sample-size 20 --report reports/live-contract/latest.json",
    "monitor:live-contract:strict": "node tools/live-contract-monitor.mjs --timeout-ms 15000 --sample-size 20 --require-security-headers --report reports/live-contract/latest.json",
    "monitor:live-browser-contract": "node tools/live-browser-contract.mjs --base-url https://www.elrincondeebano.com --timeout-ms 15000 --report reports/live-contract/browser.json",
    "cloudflare:whoami": "npx wrangler whoami",
    "cloudflare:deploy:edge-security-headers": "npx wrangler deploy --config infra/cloudflare/edge-security-headers/wrangler.toml",
    "certify:migration:prepare": "node -e \"const fs=require('fs'); ['build-determinism-a','build-determinism-b'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "certify:migration": "npm run certify:migration:prepare && npm run lint && npm run typecheck && npm run build && npm test && npm run test:e2e",
    "lighthouse:audit": "node tools/lighthouse-audit.mjs",
    "snapshot": "node tools/snapshot-site.mjs --tag dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@vitest/coverage-v8": "^4.1.3",
    "cypress": "^15.13.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "prettier": "^3.8.1",
    "purgecss": "^8.0.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "undici": "^8.0.2",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "volta": {
    "node": "22.20.0",
    "npm": "10.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortega26/elrincondeebano.git"
  },
  "bugs": {
    "url": "https://github.com/cortega26/elrincondeebano/issues"
  },
  "homepage": "https://github.com/cortega26/elrincondeebano#readme"
}
