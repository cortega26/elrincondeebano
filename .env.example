# El Rincón de Ébano — environment variables
# Copy to .env before first run: cp .env.example .env
# See docs/operations/RUNBOOK.md for per-workflow variable requirements.
# All variables are optional unless noted otherwise.

# ---------------------------------------------------------------------------
# Playwright / E2E
# ---------------------------------------------------------------------------

# Port for the local dev server used by Playwright tests.
# Default: 8081
PORT=8081

# Override the base URL Playwright connects to (e.g. point at staging).
# Default: http://127.0.0.1:$PORT
# PLAYWRIGHT_BASE_URL=https://staging.elrincondeebano.com

# Set to "1" to skip the full Astro build step before E2E tests.
# Useful when iterating on tests without changing source (uses existing dist/).
# PLAYWRIGHT_SKIP_BUILD=1

# ---------------------------------------------------------------------------
# Admin / product-data sync (disabled by default)
# See admin/product_manager/content_manager.py:44-69 for full config.
# ---------------------------------------------------------------------------

# Require auth header on every sync request (recommended in production).
# SYNC_API_REQUIRE_AUTH=true

# Fail hard on startup if sync is enabled but API base is not configured.
# SYNC_API_STRICT_STARTUP=true

# Remote API base URL — leave empty to keep sync disabled (default).
# SYNC_API_BASE=
